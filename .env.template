# ============================================================
#  CRICSHOT — Environment Configuration Template
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to Git.
# ============================================================

# ── Flask Secret Key ─────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here


# ── Email OTP via SMTP2GO (Free — 1,000 emails/month) ────────
# 1. Sign up at https://www.smtp2go.com (free plan)
# 2. Go to Settings → SMTP Users → Add SMTP User
# 3. Copy the username and password shown
#
MAIL_SERVER=mail.smtp2go.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_smtp2go_username
MAIL_PASSWORD=your_smtp2go_password
# The "From" address shown on emails (must be a verified sender in SMTP2GO)
MAIL_DEFAULT_SENDER=cricshot@yourdomain.com


# ── SMS OTP via Twilio (Free Trial) ──────────────────────────
# 1. Sign up at https://www.twilio.com (free trial credit)
# 2. Verify your own phone number in the Twilio Console
# 3. Get Account SID and Auth Token from the dashboard
# NOTE: Trial mode can only send SMS to verified numbers.
#
TWI_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWI_AUTH_TOKEN=your_twilio_auth_token
TWI_PHONE_NUMBER=+1234567890
